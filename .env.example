# ══════════════════════════════════════════════════════════════
# WHATSAPP AUDIT SYSTEM — VARIABLES DE ENTORNO
# ══════════════════════════════════════════════════════════════
# Copiar este archivo como `.env` y llenar todos los placeholders:
#   cp .env.example .env
#   nano .env
#
# Los placeholders __SET_ME__ y __SET_ME_*__ son INERTES — no son
# valores válidos. STRICT_CONFIG=true hace que la API rechace
# arrancar mientras queden sin reemplazar.
#
# Detalles de operación: docs/RUNBOOK.md
# Política de seguridad y rotación: SECURITY.md
# ══════════════════════════════════════════════════════════════

# ─── BASE DE DATOS ───────────────────────────────────────────
POSTGRES_DB=whatsapp_audit
POSTGRES_USER=wa_admin
POSTGRES_PASSWORD=__SET_ME_DB_PASSWORD__

# ─── REDIS ───────────────────────────────────────────────────
REDIS_PASSWORD=__SET_ME_REDIS_PASSWORD__

# ─── APIs DE INTELIGENCIA ARTIFICIAL ─────────────────────────
# OpenAI Whisper (transcripción de audios). Formato real: sk-...
OPENAI_API_KEY=__SET_ME_OPENAI_KEY__

# Anthropic Claude (análisis de conversaciones). Formato real: sk-ant-...
ANTHROPIC_API_KEY=__SET_ME_ANTHROPIC_KEY__

# Modelo Sonnet usado en Pass 2 del analyzer. Ver ADR-0003.
CLAUDE_MODEL=claude-sonnet-4-5

# ─── AUTENTICACIÓN DEL DASHBOARD ─────────────────────────────
# Generar con: openssl rand -hex 64
# STRICT_CONFIG=true exige >=32 chars y rechaza cualquier valor que
# empiece con __SET_ME__.
JWT_SECRET=__SET_ME_RUN_OPENSSL_RAND_HEX_64__
JWT_EXPIRY_HOURS=8

# Usuario admin del dashboard. Multi-usuario disponible vía
# `python -m src.cli_users create <usuario> <password>` (ver ADR-0002).
ADMIN_USER=__SET_ME_USERNAME__
ADMIN_PASSWORD=__SET_ME_ADMIN_PASSWORD__

# Modo estricto. Producción: SIEMPRE true.
STRICT_CONFIG=false

# ─── EXTRACCIÓN DE WHATSAPP — RATE LIMITS LOAD-BEARING ───────
# Bajar estos valores aumenta el riesgo de ban del WhatsApp del
# cliente. Ver SECURITY.md y docs/CONTEXTO_NEGOCIO.md.

# Delay entre cada chat procesado (ms)
EXTRACTION_DELAY_MIN=2000
EXTRACTION_DELAY_MAX=4000

# Delay entre cada descarga de media (ms)
MEDIA_DELAY_MIN=3000
MEDIA_DELAY_MAX=6000

# Concurrencia de descarga de media (≤5 recomendado)
MEDIA_CONCURRENCY=5

# Timeout por media (ms). Un media normal baja en <1s; 15s es generoso.
MEDIA_DOWNLOAD_TIMEOUT_MS=15000

# Circuit breaker: N media consecutivos con timeout = teléfono
# suspendido o red caída. Aborta el batch del chat actual.
ABORT_AFTER_CONSECUTIVE_TIMEOUTS=5

# Timeout del sync de historial Baileys (ms). Para 6000+ chats
# considerar 7200000 (2h) si el sync se corta antes.
SYNC_TIMEOUT_MS=3600000

# fetchMessageHistory por chat: solo si el sync inicial trajo
# MENOS de MIN_MSGS_FOR_SKIP_FETCH mensajes. Crítico para 6000+ chats.
MIN_MSGS_FOR_SKIP_FETCH=30
FETCH_HISTORY_MAX_BATCHES=5
FETCH_HISTORY_SLEEP_MS=3000

# Reintentos máximos por operación fallida
MAX_RETRIES=3

# ─── TRANSCRIPCIÓN ───────────────────────────────────────────
TRANSCRIBER_WORKERS=3
CONFIDENCE_THRESHOLD=0.80
WHISPER_TIMEOUT_SECONDS=120

# ─── ANÁLISIS CON IA ─────────────────────────────────────────
# Cada análisis cuesta plata. Ver ADR-0003 (two-pass Haiku+Sonnet)
# y la sección de costos en docs/RUNBOOK.md.
ANALYZER_WORKERS=2

# ─── EXTRACCIÓN POR LOTES (modo `index`) ─────────────────────
# Fecha tope (INCLUSIVA, hora Bogotá) para indexar chats. Default
# 2030-12-31 = sin filtrado. Ejemplo para indexar solo chats inactivos
# desde el 20-mar: EXTRACTION_CUTOFF_DATE=2026-03-20. Ver ADR-0005.
EXTRACTION_CUTOFF_DATE=2030-12-31

# ─── SERVIDOR / DOMINIO ──────────────────────────────────────
# Dominio apuntando al servidor (para SSL + CORS). Vacío en dev.
DOMAIN=

# URL pública que el dashboard usará para llamar a la API.
# En producción típicamente igual al dominio (vacío); en dev,
# http://localhost:8000 si corres fuera de docker.
NEXT_PUBLIC_API_URL=

# Orígenes CORS adicionales (coma-separados). Opcional.
CORS_EXTRA_ORIGINS=

# ─── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=INFO
