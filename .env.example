# ══════════════════════════════════════════════════════════════
# WHATSAPP AUDIT SYSTEM — VARIABLES DE ENTORNO
# ══════════════════════════════════════════════════════════════
# Copia este archivo como .env y llena todos los valores
#   cp .env.example .env
#   nano .env
# ══════════════════════════════════════════════════════════════

# ─── BASE DE DATOS ───────────────────────────────────────────
POSTGRES_DB=whatsapp_audit
POSTGRES_USER=wa_admin
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_AQUI

# ─── REDIS ───────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_AQUI

# ─── APIs DE INTELIGENCIA ARTIFICIAL ─────────────────────────
# OpenAI (para Whisper — transcripción de audios)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (para Claude — análisis de conversaciones)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de Claude a usar
CLAUDE_MODEL=claude-sonnet-4-5

# ─── AUTENTICACIÓN DEL DASHBOARD ─────────────────────────────
# Secreto para firmar tokens JWT (generar con: openssl rand -hex 64)
# STRICT_CONFIG=true exige que sea >=32 chars y ≠ "change-me-in-prod".
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_LARGO_MIN_32_CHARS
JWT_EXPIRY_HOURS=8

# Usuario y contraseña del dashboard
ADMIN_USER=CAMBIAR_POR_USUARIO
ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_AQUI

# Modo estricto de configuración (producción = true)
STRICT_CONFIG=false

# ─── EXTRACCIÓN DE WHATSAPP ──────────────────────────────────
# Delay entre cada chat (milisegundos) — MÁS ALTO = MÁS SEGURO
EXTRACTION_DELAY_MIN=2000
EXTRACTION_DELAY_MAX=4000

# Delay entre cada descarga de media (milisegundos)
MEDIA_DELAY_MIN=3000
MEDIA_DELAY_MAX=6000

# Concurrencia de descarga de media (≤5 recomendado para evitar ban)
MEDIA_CONCURRENCY=5

# Timeout del sync de historial Baileys (milisegundos)
SYNC_TIMEOUT_MS=180000

# Reintentos máximos por operación fallida
MAX_RETRIES=3

# ─── TRANSCRIPCIÓN ───────────────────────────────────────────
# Workers paralelos para transcripción (no pasar de 3)
TRANSCRIBER_WORKERS=3

# Umbral mínimo de confianza (0.0 a 1.0)
CONFIDENCE_THRESHOLD=0.80

# Timeout (segundos) por llamada a Whisper
WHISPER_TIMEOUT_SECONDS=120

# ─── ANÁLISIS CON IA ─────────────────────────────────────────
# Workers paralelos para análisis (no pasar de 2)
ANALYZER_WORKERS=2

# ─── SERVIDOR / DOMINIO ──────────────────────────────────────
# Dominio apuntando al servidor (para SSL + CORS). Vacío en dev.
DOMAIN=

# URL pública que el dashboard usará para llamar a la API.
# En producción típicamente igual al mismo dominio (''); en dev,
# algo como http://localhost:8000 si corres fuera de docker.
NEXT_PUBLIC_API_URL=

# Orígenes CORS adicionales (coma-separados). Opcional.
# CORS_EXTRA_ORIGINS=https://staging.tudominio.com,https://otro.tudominio.com
CORS_EXTRA_ORIGINS=

# ─── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=INFO
